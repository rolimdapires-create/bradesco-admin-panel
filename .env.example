# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Railway MySQL connection string
# Format: mysql://username:password@host:port/database
DATABASE_URL=mysql://root:password@localhost:3306/bradesco_admin

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# Port for the Express server (Railway will set PORT automatically)
PORT=3000

# Node environment
NODE_ENV=production

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
# Application name
APP_NAME=Bradesco Admin Panel

# ============================================================================
# SECURITY
# ============================================================================
# JWT Secret for session tokens (generate a random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ============================================================================
# OPTIONAL: OAuth/Authentication (if needed)
# ============================================================================
# OAUTH_SERVER_URL=https://api.example.com
# VITE_APP_ID=your-app-id
# OWNER_OPEN_ID=owner-id
# OWNER_NAME=Owner Name
