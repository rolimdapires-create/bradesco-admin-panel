#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../global/v11/12-19e247a374a/node_modules/@googleworkspace/cli/run-gws.js" "$@"
else
  exec node  "$basedir/../global/v11/12-19e247a374a/node_modules/@googleworkspace/cli/run-gws.js" "$@"
fi
# cmd-shim-target=/home/ubuntu/.local/share/pnpm/global/v11/12-19e247a374a/node_modules/@googleworkspace/cli/run-gws.js
