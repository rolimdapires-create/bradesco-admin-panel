//FunÁ„o que filtra os caracteres digitados, ' ou ", para
//evitar erro no objeto Json
function filtrarCaracteresDigitados(key,campo){

	var code = window.event ? window.event.keyCode : key.which;

	if (code == 0
			||code == 8   /*Backspace*/
			|| code == 9  /*Tab*/
			|| code == 13 /*Esc*/
			|| code == 27){ /*Enter*/
		return true;
	}

	//Verificando se s„o caracteres v·lidos
	var reg = null;
	if(campo==null){
		reg = new RegExp(/[^\'^\"]/gi);
	}
	else
	if(campo=="email"){
		reg = new RegExp(/[a-zA-Z0-9@\.\_\-]/gi);
	}


	var charCode = String.fromCharCode(code);
	if (!reg.test(charCode)) {
		if (key.preventDefault){ //standard browsers
			key.preventDefault();
		}else{ // internet explorer
			key.returnValue = false;
		}
		return;
	}
}

