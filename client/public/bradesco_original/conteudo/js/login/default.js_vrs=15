function urlRewrite(urlOriginal, urlRewrited) {
    var retorno;
    var posJsessionId = urlRewrited.indexOf(";");
    if (posJsessionId >= 0) {
        var jsessionId = urlRewrited.substring(posJsessionId);
        var posJessionIdOri = urlOriginal.indexOf(";");
        var posParamOri = urlOriginal.indexOf("?");
        var urlOriPath = urlOriginal;
        var urlOriParam = "";
        if (posParamOri >= 0) {
            urlOriParam = urlOriginal.substring(posParamOri);
        }
        if (posJessionIdOri >= 0) {
            urlOriPath = urlOriginal.substring(0, posJessionIdOri);
        } else if (posParamOri >= 0) {
            urlOriPath = urlOriginal.substring(0, posParamOri);
        }
        retorno = urlOriPath + jsessionId + urlOriParam;
    } else {
        retorno = urlOriginal;
    }
