      if (typeof isPluginCadMaq == 'boolean' && isPluginCadMaq) {
         $.ajax({
            type: 'POST',
            url: urlAutenticacao,
            data: obterParametrosAjaxAutenticacaoPluginCadMaq(valorEntrada),
            error: erroGlobal,
            success: resultadoAutenticacaoDispositivoAtual,
            timeout: ajaxTimeOut
         });
